# ============================================================
# OSINT Knowledge Graph - Environment configuration example
# Copy to `.env` and adjust. NEVER commit the real .env file.
# ============================================================

# ---- General ----
ENVIRONMENT=development
LOG_LEVEL=INFO

# ---- FastAPI ----
API_HOST=0.0.0.0
API_PORT=8000
API_CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# ---- PostgreSQL (raw data & logs) ----
POSTGRES_USER=osint
POSTGRES_PASSWORD=change_me_postgres
POSTGRES_DB=osint
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

# ---- Neo4j (knowledge graph) ----
# NEO4J_AUTH format is "user/password" (consumed by the official image).
NEO4J_AUTH=neo4j/change_me_neo4j
NEO4J_URI=bolt://neo4j:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=change_me_neo4j

# ---- Redis (cache + Celery result backend) ----
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_DB=0

# ---- RabbitMQ (Celery broker) ----
RABBITMQ_DEFAULT_USER=osint
RABBITMQ_DEFAULT_PASS=change_me_rabbit
RABBITMQ_HOST=rabbitmq
RABBITMQ_PORT=5672
RABBITMQ_MANAGEMENT_PORT=15672

# ---- Celery (derived URLs; override if needed) ----
CELERY_BROKER_URL=amqp://osint:change_me_rabbit@rabbitmq:5672//
CELERY_RESULT_BACKEND=redis://redis:6379/0

# ---- External data sources (feature flags) ----
GDELT_ENABLED=true
HACKERNEWS_ENABLED=true
REDDIT_ENABLED=false

# ---- GDELT 2.0 ----
GDELT_BASE_URL=http://data.gdeltproject.org/gdeltv2
# Cap rows mapped from a single 15-minute GKG file (0 = no limit).
GDELT_GKG_MAX_RECORDS=250

# ---- Reddit API (PRAW) ----
# Create an app at https://www.reddit.com/prefs/apps (type: "script").
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_USER_AGENT=osint-knowledge-graph/0.1
REDDIT_SUBREDDITS=worldnews,business
REDDIT_HOT_LIMIT=25

# ---- Ingestion schedule (Celery Beat, minutes) ----
INGEST_GDELT_INTERVAL_MINUTES=15
INGEST_REDDIT_INTERVAL_MINUTES=15

# ---- NLP / NER (Phase 3) ----
NLP_ENABLED=true
# Fast model to start; swap for en_core_web_trf (needs the `nlp` extra) later.
SPACY_MODEL=en_core_web_sm
NLP_QUEUE_NAME=nlp_tasks
# Co-occurrence granularity for relations: "sentence" or "paragraph".
NLP_COOCCURRENCE_SCOPE=sentence
NLP_DISPATCH_BATCH_SIZE=100
NLP_DISPATCH_INTERVAL_MINUTES=5

# ---- Knowledge graph sync (Phase 4) ----
GRAPH_SYNC_ENABLED=true
# Articles pushed to Neo4j per UNWIND batch.
GRAPH_SYNC_BATCH_SIZE=100
GRAPH_SYNC_INTERVAL_MINUTES=5

# ---- Graph API (Phase 5) ----
# Default look-back window (hours) for GET /entities.
API_ENTITIES_WINDOW_HOURS=24
# Ego-graph neighbor fan-out per hop (default and hard cap).
GRAPH_DEFAULT_NEIGHBOR_LIMIT=25
GRAPH_MAX_NEIGHBOR_LIMIT=200
# Pagination defaults for list endpoints.
API_DEFAULT_PAGE_SIZE=50
API_MAX_PAGE_SIZE=200

# ---- Redis cache (Phase 5) ----
CACHE_ENABLED=true
# TTL (seconds) for cached graph reads (5-10 minutes recommended).
CACHE_TTL_SECONDS=300
CACHE_KEY_PREFIX=osint:cache
